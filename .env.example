# yantresh-hub — environment template. Copy to .env, fill in, never commit it.
# This is the committed config contract. Keep real secrets only in .env.

# ---- Root domain ----
# Bare apex. Redirects (301) to PORTFOLIO_ADDRESS — serves no content itself.
DOMAIN=example.com

# ---- TLS ----
# Caddy's automatic HTTPS uses this for ACME (Let's Encrypt) registration
# and expiry notices. Any mailbox you control.
ACME_EMAIL=you@example.com

# ---- Projects ----
# One ADDRESS line per project. Default = subdomain of DOMAIN.
# To move a project to its own domain later: change this value + update DNS.
# No Caddyfile edit needed — each block already reads {$<NAME>_ADDRESS}.
PORTFOLIO_ADDRESS=portfolio.example.com
YANTRESH_ADDRESS=yantresh.example.com
SROTANTRA_ADDRESS=srotantra.example.com

# ---- Yantresh Commerce ----
STORE_IMAGE_TAG=main
ADMIN_IMAGE_TAG=main
MEDUSA_IMAGE_TAG=main
WORKER_IMAGE_TAG=main

STOREFRONT_IMAGE=ghcr.io/${GHCR_OWNER}/yantresh-commerce-storefront:${STORE_IMAGE_TAG}
ADMIN_IMAGE=ghcr.io/${GHCR_OWNER}/yantresh-commerce-admin:${ADMIN_IMAGE_TAG}
MEDUSA_IMAGE=ghcr.io/${GHCR_OWNER}/yantresh-commerce-medusa:${MEDUSA_IMAGE_TAG}
WORKER_IMAGE=ghcr.io/${GHCR_OWNER}/yantresh-commerce-worker:${WORKER_IMAGE_TAG}

SHOP_API_ADDRESS=shop-api.${DOMAIN}
SHOP_ADMIN_ADDRESS=shop-admin.${DOMAIN}
COMMERCE_STOREFRONT_ADDRESS=commerce.${DOMAIN}
DEMO_STORE_ADDRESS=demo-store.${DOMAIN}
STOREFRONT_TLS_ASK_URL=http://yantresh-commerce-storefront:3000/api/tls/authorize

POSTGRES_PASSWORD=
DATABASE_URL=
MEDUSA_DATABASE_URL=
REDIS_URL=
SECRET_MASTER_KEY=

# ---- yantresh-os (project: yantresh) secrets ----
YANTRESH_API_KEY=
DEEPSEEK_API_KEY=

# ---- Container images (GHCR — built by each project's own CI; the VPS
# only ever `docker compose pull`s these, never builds) ----
# GitHub org/user that owns the GHCR packages, e.g. "yashpatel1503".
GHCR_OWNER=

# Per-project tags. "main" tracks the latest build of each project's
# default branch; pin to a release tag/sha to freeze a project in place.
PORTFOLIO_IMAGE_TAG=main
YANTRESH_IMAGE_TAG=main
SROTANTRA_IMAGE_TAG=main

# ---- State backups (deploy/backup-state.sh + yantresh-backup.timer) ----
# Where to write yantresh_state archives, and how many to keep. Optional —
# defaults are ./backups and 14. Uncomment to override.
# BACKUP_DIR=/var/backups/yantresh
# BACKUP_KEEP=30
# Off-host copy (optional): an rclone remote to push each archive to, so a
# VPS loss can't take the only copy. Needs rclone installed + configured.
# BACKUP_REMOTE=s3:my-bucket/yantresh

# ---- Platform ----
# Image platform pulled for each service. Matches the VPS architecture —
# "linux/arm64" for ARM64 hosts (e.g. Ampere/Graviton), "linux/amd64" for x86.
DOCKER_PLATFORM=linux/arm64
