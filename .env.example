# yantresh-hub — environment template. Copy to .env, fill in, never commit it.
# Nothing in this repo hardcodes a domain, project name, or repo name —
# everything below is the single place those live.

# ---- Root domain ----
# Buy this later; placeholder until then. Portfolio is served here.
DOMAIN=example.com

# ---- TLS ----
# Caddy's automatic HTTPS uses this for ACME (Let's Encrypt) registration
# and expiry notices. Any mailbox you control.
ACME_EMAIL=you@example.com

# ---- Projects ----
# One ADDRESS line per project. Default = subdomain of DOMAIN.
# To move a project to its own domain later: change this value + update DNS.
# No Caddyfile edit needed — the block already reads {$YANTRESH_ADDRESS}.
YANTRESH_ADDRESS=yantresh.example.com

# ---- yantresh-os (project: yantresh) secrets ----
YANTRESH_API_KEY=
DEEPSEEK_API_KEY=

# ---- Container images (GHCR — built by each project's own CI; the VPS
# only ever `docker compose pull`s these, never builds) ----
# GitHub org/user that owns the GHCR packages, e.g. "yashpatel1503".
GHCR_OWNER=

# Per-project tags. "main" tracks the latest build of each project's
# default branch; pin to a release tag/sha to freeze a project in place.
PORTFOLIO_IMAGE_TAG=main
YANTRESH_IMAGE_TAG=main

# ---- Platform ----
# Image platform pulled for each service. Matches the VPS architecture —
# "linux/arm64" for ARM64 hosts (e.g. Ampere/Graviton), "linux/amd64" for x86.
DOCKER_PLATFORM=linux/arm64
