# yantresh-hub Caddyfile — one block per public address.
# {$VAR} is substituted from .env at container start (Caddy native feature).
# Yantresh Commerce uses fixed public hostnames by design.

{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://yantresh-commerce-storefront:3000/api/tls/authorize
	}
}

# Baseline security headers for services that don't set their own.
# (patel-portfolio ships a fuller set, including CSP, from its own nginx —
# don't import this there, to keep one source of truth per response.)
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
		-Server
	}
}

# Root domain redirects to the portfolio subdomain (path + query preserved).
{$DOMAIN} {
	import security_headers
	redir https://{$PORTFOLIO_ADDRESS}{uri} permanent
}

{$PORTFOLIO_ADDRESS} {
	reverse_proxy portfolio:8080
}

{$YANTRESH_ADDRESS} {
	import security_headers
	reverse_proxy yantresh-api:8000
}

{$SROTANTRA_ADDRESS} {
	import security_headers
	reverse_proxy srotantra-api:8000
}

# Yantresh Commerce
shop-api.yantresh.com {
	reverse_proxy yantresh-commerce-medusa:9000
}

shop-admin.yantresh.com {
	reverse_proxy yantresh-commerce-admin:3000
}

commerce.yantresh.com, demo-store.yantresh.com {
	reverse_proxy yantresh-commerce-storefront:3000
}

# --- Adding a new project ---
# 1. docker-compose.yml: add a "<name>-api" service,
#    image: ghcr.io/${GHCR_OWNER}/<name>:${<NAME>_IMAGE_TAG:-main}
# 2. .env: add "<NAME>_ADDRESS=<name>.{$DOMAIN}" (or a domain of its own)
#    and "<NAME>_IMAGE_TAG=main"
# 3. below: add a block ->  {$<NAME>_ADDRESS} { reverse_proxy <name>-api:<port> }
# 4. DNS: point <NAME>_ADDRESS at this host
#
# Moving a project to its own domain later: change its *_ADDRESS value in
# .env + update DNS. No Caddyfile edit needed — the block already reads
# {$<NAME>_ADDRESS}, whatever that resolves to.
